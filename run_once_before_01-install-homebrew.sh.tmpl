#!/usr/bin/env bash
# run_once_before_01-install-homebrew.sh.tmpl
# Installs Xcode CLT, Homebrew, and runs brew bundle.
# Only executes on macOS.
{{ if eq .chezmoi.os "darwin" -}}
set -euo pipefail

mkdir -p "$HOME/.config"

echo "==> Checking Xcode Command Line Tools..."
if ! xcode-select -p &>/dev/null; then
  echo "==> Installing Xcode Command Line Tools (click Install in the dialog)..."
  xcode-select --install
  until xcode-select -p &>/dev/null; do sleep 5; done
  echo "==> Xcode CLT installed."
else
  echo "==> Xcode CLT already installed."
fi

echo "==> Checking Homebrew..."
if ! command -v brew &>/dev/null; then
  echo "==> Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Add brew to PATH for Apple Silicon
  if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
  echo "==> Homebrew installed."
else
  echo "==> Homebrew already installed."
fi

echo "==> Installing chezmoi via brew..."
brew install chezmoi

echo "==> Running brew bundle..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || echo "==> Some packages failed, continuing..."
echo "==> brew bundle complete."
{{ end -}}
