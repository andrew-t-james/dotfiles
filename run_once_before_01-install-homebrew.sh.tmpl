#!/usr/bin/env bash
# run_once_before_01-install-homebrew.sh.tmpl
# Installs Xcode CLT, Homebrew, and runs brew bundle.
# Only executes on macOS.
{{ if eq .chezmoi.os "darwin" -}}
set -euo pipefail

mkdir -p "$HOME/.config"

# ─── Xcode CLT ───────────────────────────────────────────────────────────────
echo "==> Checking Xcode Command Line Tools..."
if ! xcode-select -p &>/dev/null; then
  echo ""
  echo "  Xcode Command Line Tools are not installed."
  echo "  Run this and wait for it to finish:"
  echo ""
  echo "    xcode-select --install"
  echo ""
  echo "  Then re-run the bootstrap:"
  echo ""
  echo "    sh -c \"\$(curl -fsLS get.chezmoi.io)\" -- init --source ~/dotfiles --apply andrew-t-james/dotfiles"
  echo ""
  exit 1
fi
echo "==> Xcode CLT OK."

# ─── Homebrew ────────────────────────────────────────────────────────────────
echo "==> Checking Homebrew..."
BREW_BIN="/opt/homebrew/bin/brew"
[[ -x "$BREW_BIN" ]] || BREW_BIN="/usr/local/bin/brew"

if [[ ! -x "$BREW_BIN" ]]; then
  echo "==> Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  BREW_BIN="/opt/homebrew/bin/brew"
  [[ -x "$BREW_BIN" ]] || BREW_BIN="/usr/local/bin/brew"
  echo "==> Homebrew installed."
else
  echo "==> Homebrew already installed."
fi

eval "$("$BREW_BIN" shellenv)"

# ─── chezmoi ─────────────────────────────────────────────────────────────────
echo "==> Installing chezmoi via brew..."
brew install chezmoi

# ─── Brewfile ────────────────────────────────────────────────────────────────
echo "==> Running brew bundle..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile" || echo "==> Some packages failed, continuing..."
echo "==> brew bundle complete."
{{ end -}}
