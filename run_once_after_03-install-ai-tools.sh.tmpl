#!/usr/bin/env bash
# run_once_after_03-install-ai-tools.sh.tmpl
set -euo pipefail

echo "==> Installing AI CLI tools..."

# Install oh-my-claudecode
if ! claude mcp list 2>/dev/null | grep -q 'oh-my-claudecode'; then
  claude mcp install oh-my-claudecode 2>/dev/null || true
fi

# Install oh-my-codex (omx setup regenerates OMX config sections)
if command -v codex &>/dev/null; then
  if ! command -v omx &>/dev/null; then
    npm install -g oh-my-codex 2>/dev/null || bun install -g oh-my-codex 2>/dev/null || true
  fi
fi

echo "==> AI tools installed."
